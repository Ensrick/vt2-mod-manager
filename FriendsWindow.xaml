<Window x:Class="Vt2ModManager.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage friends"
        Width="780" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        TextElement.Foreground="#EAEAEA"
        FontFamily="Segoe UI" FontSize="13"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="RowBackground" Value="#252525" />
            <Setter Property="AlternatingRowBackground" Value="#2B2B2B" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Extended" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#BBBBBB" />
            <Setter Property="BorderBrush" Value="#1A1A1A" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#37404F" />
                    <Setter Property="Foreground" Value="#EAEAEA" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Background" Value="#2D5FAF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#A14336" />
        </Style>
        <Style TargetType="Button" x:Key="SubtleButton" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="CaretBrush" Value="#EAEAEA" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusLabel" Text="" Foreground="#888" />
                <Button DockPanel.Dock="Right" Content="Close" Style="{StaticResource SubtleButton}" Click="OnCloseClicked" />
            </DockPanel>
        </Border>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="SteamID, vanity, or URL:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="AddBox" Width="340" KeyDown="OnAddBoxKeyDown" />
            <Button Content="Add"              Style="{StaticResource ActionButton}" Click="OnAddClicked" />
            <Button Content="Remove selected"  Style="{StaticResource DangerButton}" Click="OnRemoveClicked" />
            <Button Content="Toggle favorite"  Style="{StaticResource SubtleButton}" Click="OnToggleFavoriteClicked" />
            <Button Content="Refresh selected" Style="{StaticResource SubtleButton}" Click="OnRefreshClicked" />
            <Button Content="Refresh all"      Style="{StaticResource SubtleButton}" Click="OnRefreshAllClicked" />
        </StackPanel>

        <DataGrid x:Name="FriendsGrid" IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Show" Binding="{Binding Favorite, UpdateSourceTrigger=PropertyChanged}" Width="56" />
                <DataGridTextColumn Header="Name"        Binding="{Binding DisplayName}"        Width="2*" IsReadOnly="True" />
                <DataGridTextColumn Header="Origin"      Binding="{Binding OriginBadge}"        Width="80" IsReadOnly="True" />
                <DataGridTextColumn Header="SteamID64"   Binding="{Binding SteamId64}"          Width="180" IsReadOnly="True" />
                <DataGridTextColumn Header="Visibility"  Binding="{Binding VisibilityText}"     Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Mods"        Binding="{Binding ModCountText}"       Width="70" IsReadOnly="True" />
                <DataGridTextColumn Header="Last fetch"  Binding="{Binding LastFetchedDisplay}" Width="160" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
