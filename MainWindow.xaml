<Window x:Class="Vt2ModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VT2 Mod Manager"
        Width="1200" Height="780"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        TextElement.Foreground="#EAEAEA"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="#252525" />
            <Setter Property="Foreground"           Value="#EAEAEA" />
            <Setter Property="RowBackground"        Value="#252525" />
            <Setter Property="AlternatingRowBackground" Value="#2B2B2B" />
            <Setter Property="GridLinesVisibility"  Value="None" />
            <Setter Property="BorderThickness"      Value="0" />
            <Setter Property="HeadersVisibility"    Value="Column" />
            <Setter Property="AutoGenerateColumns"  Value="False" />
            <Setter Property="CanUserAddRows"       Value="False" />
            <Setter Property="CanUserDeleteRows"    Value="False" />
            <Setter Property="CanUserResizeRows"    Value="False" />
            <Setter Property="SelectionMode"        Value="Extended" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="#1A1A1A" />
            <Setter Property="Foreground"  Value="#BBBBBB" />
            <Setter Property="BorderBrush" Value="#1A1A1A" />
            <Setter Property="Padding"     Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding"     Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#37404F" />
                    <Setter Property="Foreground" Value="#EAEAEA" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Padding"          Value="10,4" />
            <Setter Property="Margin"           Value="4,2" />
            <Setter Property="Background"       Value="#2D5FAF" />
            <Setter Property="Foreground"       Value="White" />
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="Cursor"           Value="Hand" />
        </Style>
        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#A14336" />
        </Style>
        <Style TargetType="Button" x:Key="SubtleButton" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding"          Value="14,6" />
            <Setter Property="Background"       Value="#2A2A2A" />
            <Setter Property="Foreground"       Value="#CCCCCC" />
            <Setter Property="BorderBrush"      Value="#1E1E1E" />
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#37404F" />
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#5A9BFF" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333A45" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="#1E1E1E" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#1A1A1A" />
            <Setter Property="Foreground"  Value="#EAEAEA" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Padding"     Value="6,3" />
            <Setter Property="CaretBrush"  Value="#EAEAEA" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAEAEA" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="#1A1A1A" />
            <Setter Property="Foreground"   Value="#EAEAEA" />
            <Setter Property="BorderBrush"  Value="#3A3A3A" />
            <Setter Property="Padding"      Value="6,3" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#1A1A1A" />
            <Setter Property="Foreground"      Value="#EAEAEA" />
            <Setter Property="BorderBrush"     Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#161616" Padding="12,6">
            <DockPanel>
                <TextBlock x:Name="StatusLabel" Text="Ready." Foreground="#888" />
                <TextBlock x:Name="VersionLabel" DockPanel.Dock="Right" Foreground="#555" />
            </DockPanel>
        </Border>

        <!-- Update-available banner. Sits above the top toolbar; hidden by default and
             only revealed when UpdateChecker reports a newer release. "Later" dismisses
             for the session; it reappears next launch if the update still isn't installed. -->
        <Border x:Name="UpdateBanner" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#2D5FAF" BorderBrush="#7AB0FF" BorderThickness="0,0,0,2"
                Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="UpdateBannerInstallButton" Content="Update now"
                            Style="{StaticResource ActionButton}" Background="#1A1A1A"
                            Margin="0,0,8,0" Click="OnUpdateClicked" />
                    <Button x:Name="UpdateBannerLaterButton" Content="Later"
                            Style="{StaticResource ActionButton}" Background="#3A4658"
                            Click="OnUpdateBannerLaterClicked" />
                </StackPanel>
                <TextBlock x:Name="UpdateBannerText" VerticalAlignment="Center"
                           Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="#161616" Padding="12,8">
            <DockPanel>
                <TextBlock Text="VT2 Mod Manager" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <CheckBox x:Name="ModdedRealmCheck" Content="Modded realm" IsChecked="True"
                              VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="Launch VT2 (bypass launcher)" Style="{StaticResource ActionButton}" Click="OnLaunchDirectClicked" />
                    <Button Content="Launch via Steam"             Style="{StaticResource SubtleButton}" Click="OnLaunchViaSteamClicked" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabs">

            <!-- ========================= TAB 1: MODS ========================= -->
            <TabItem Header="Mods">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Mods" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Reload"        Style="{StaticResource SubtleButton}" Margin="16,0,0,0" Click="OnReloadClicked" />
                        <Button Content="Move up"       Style="{StaticResource SubtleButton}" Click="OnMoveUpClicked" />
                        <Button Content="Move down"     Style="{StaticResource SubtleButton}" Click="OnMoveDownClicked" />
                        <Button Content="Move to top"   Style="{StaticResource SubtleButton}" Click="OnMoveTopClicked" />
                        <Button Content="Move to bottom" Style="{StaticResource SubtleButton}" Click="OnMoveBottomClicked" />
                        <Button Content="Enable all"    Style="{StaticResource SubtleButton}" Click="OnEnableAllClicked" />
                        <Button Content="Disable all"   Style="{StaticResource SubtleButton}" Click="OnDisableAllClicked" />
                        <Button Content="Auto-sort"     Style="{StaticResource SubtleButton}" Click="OnAutoSortClicked" />
                        <Button Content="Refresh from Workshop" Style="{StaticResource SubtleButton}" Click="OnRefreshFromWorkshopClicked" />
                        <Button Content="Export collection" Style="{StaticResource SubtleButton}" Click="OnExportCollectionClicked" />
                        <Button Content="Save"          Style="{StaticResource ActionButton}" Click="OnSaveClicked" />
                    </StackPanel>

                    <DockPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock x:Name="ModsHint" DockPanel.Dock="Right" Foreground="#888" VerticalAlignment="Center"
                                   Text="Close VT2 + launcher before saving. A .bak is kept." />
                        <TextBlock Text="Filter:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="FilterBox" Width="320" TextChanged="OnFilterChanged" />
                    </DockPanel>

                    <DataGrid Grid.Row="2" x:Name="ModsGrid" IsReadOnly="False" CanUserSortColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"        Binding="{Binding Order}"       Width="36"  IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="On"   Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="48" />
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"        Width="3*"  IsReadOnly="True" />
                            <DataGridTextColumn Header="Author"   Binding="{Binding Author}"      Width="160" IsReadOnly="True" />
                            <DataGridTextColumn Header="Status"   Binding="{Binding Status}"      Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Updated"  Binding="{Binding LastUpdated}" Width="180" IsReadOnly="True" />
                            <DataGridTextColumn Header="Size"     Binding="{Binding LocalSizeText}" Width="90" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="Size?" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeMatchIcon}" ToolTip="{Binding SizeMatchTooltip}"
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Fresh" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FreshnessIcon}" ToolTip="{Binding FreshnessTooltip}"
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Workshop ID" Binding="{Binding Id}"       Width="120" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="" Width="260">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Folder"    Style="{StaticResource SubtleButton}" Click="OnOpenModFolderClicked" />
                                            <Button Content="Open page" Style="{StaticResource SubtleButton}" Click="OnOpenWorkshopPageClicked" />
                                            <Button Content="Subscribe" Style="{StaticResource ActionButton}" Click="OnSubscribeClicked"
                                                    Visibility="{Binding IsVirtual, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ========================= TAB 2: PROFILES ========================= -->
            <TabItem Header="Profiles">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Profiles" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBox x:Name="NewProfileNameBox" Width="240" Margin="16,0,4,0" />
                        <Button Content="Save current as profile" Style="{StaticResource ActionButton}" Click="OnSaveProfileClicked" />
                        <Button Content="Apply selected profile"  Style="{StaticResource ActionButton}" Click="OnApplyProfileClicked" />
                        <Button Content="Delete selected"         Style="{StaticResource DangerButton}" Click="OnDeleteProfileClicked" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Foreground="#888" Margin="0,0,0,8"
                               Text="Apply overlays the saved enabled/order onto current mods. Mods in the profile that you don't have subscribed are skipped." />

                    <DataGrid Grid.Row="2" x:Name="ProfilesGrid" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"        Binding="{Binding Name}"          Width="2*" />
                            <DataGridTextColumn Header="Mods"        Binding="{Binding EntryCount}"    Width="80" />
                            <DataGridTextColumn Header="Enabled"     Binding="{Binding EnabledCount}"  Width="80" />
                            <DataGridTextColumn Header="Saved"       Binding="{Binding SavedDisplay}"  Width="180" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}"   Width="3*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ========================= TAB 3: FRIENDS ========================= -->
            <TabItem Header="Friends">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Friends" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBox x:Name="AddFriendBox" Width="320" Margin="16,0,4,0"
                                 ToolTip="SteamID64, vanity name, or full profile URL" />
                        <Button Content="Add"               Style="{StaticResource ActionButton}" Click="OnAddFriendClicked" />
                        <Button Content="Remove selected"   Style="{StaticResource DangerButton}" Click="OnRemoveFriendClicked" />
                        <Button Content="Toggle favorite"   Style="{StaticResource SubtleButton}" Click="OnToggleFavoriteClicked" />
                        <Button Content="Refresh selected"  Style="{StaticResource SubtleButton}" Click="OnRefreshFriendClicked" />
                        <Button Content="Refresh all"       Style="{StaticResource SubtleButton}" Click="OnRefreshAllFriendsClicked" />
                        <Button Content="Sync columns"      Style="{StaticResource ActionButton}" Click="OnSyncFriendColumnsClicked"
                                ToolTip="Rebuild the friend columns on the Mods tab and surface mods you don't have" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Foreground="#888" Margin="0,0,0,8"
                               Text="Adding a friend fetches their public Workshop subscriptions for VT2. Friends-only / private profiles return Visibility=Private. Click Sync columns to refresh the per-friend columns on the Mods tab." />

                    <DataGrid Grid.Row="2" x:Name="FriendsGrid" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="★"          Binding="{Binding FavoriteIcon}"     Width="32" />
                            <DataGridTextColumn Header="Name"       Binding="{Binding DisplayName}"      Width="2*" />
                            <DataGridTextColumn Header="SteamID64"  Binding="{Binding SteamId64}"        Width="180" />
                            <DataGridTextColumn Header="Visibility" Binding="{Binding VisibilityText}"   Width="100" />
                            <DataGridTextColumn Header="Mods"       Binding="{Binding ModCountText}"     Width="80" />
                            <DataGridTextColumn Header="Last fetch" Binding="{Binding LastFetchedDisplay}" Width="160" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ========================= TAB 4: CONFLICTS ========================= -->
            <TabItem Header="Conflicts">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Conflicts" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Scan enabled mods" Style="{StaticResource ActionButton}" Margin="16,0,0,0" Click="OnScanConflictsClicked" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" x:Name="ConflictsHint" Foreground="#888" Margin="0,0,0,8"
                               Text="Tier-1 static scan: hook_origin collisions, VMF setting_id collisions, BuffTemplates literal-key collisions. Bundle-only mods (no loose source) are skipped." />

                    <DataGrid Grid.Row="2" x:Name="ConflictsGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                            <DataGridTextColumn Header="Kind"     Binding="{Binding Kind}"     Width="120" />
                            <DataGridTextColumn Header="Key"      Binding="{Binding Key}"      Width="240" />
                            <DataGridTextColumn Header="Mods"     Binding="{Binding ModNames}" Width="3*" />
                            <DataGridTextColumn Header="Detail"   Binding="{Binding Detail}"   Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
